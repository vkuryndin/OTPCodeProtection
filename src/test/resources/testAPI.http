### =====================================
### 1. HEALTH
### =====================================

### Health check
GET {{host}}/health
Accept: text/plain

### Database health check
GET {{host}}/health/db
Accept: application/json

### =====================================
### 2. REGISTER - SUCCESS CASES
### =====================================

### Register admin - valid
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "admin",
  "password": "12345678",
  "role": "ADMIN",
  "email": "admin@test.com"
}

### Register user - valid
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "user_3",
  "password": "12345678",
  "role": "USER",
  "email": "user2@test.com",
  "phone": "+37400112233",
  "telegramChatId": "123456789"
}

### =====================================
### 3. REGISTER - VALIDATION ERRORS
### =====================================

### Register - login is required
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "",
  "password": "12345678",
  "role": "USER"
}

### Register - login too short
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "ab",
  "password": "12345678",
  "role": "USER"
}

### Register - login invalid chars
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "user!*",
  "password": "12345678",
  "role": "USER"
}

### Register - password is required
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "user2",
  "password": "",
  "role": "USER"
}

### Register - password too short
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "user3",
  "password": "1234567",
  "role": "USER"
}

### Register - role is required
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "user4",
  "password": "12345678"
}

### =====================================
### 4. REGISTER - BUSINESS RULE ERRORS
### =====================================

### Register - duplicate login
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "admin",
  "password": "12345678",
  "role": "USER"
}

### Register - second admin
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "admin2",
  "password": "12345678",
  "role": "ADMIN"
}

### =====================================
### 5. LOGIN
### =====================================

### Login as admin - valid
POST {{host}}/auth/login
Content-Type: application/json

{
  "login": "admin",
  "password": "12345678"
}

### Login as user - valid
POST {{host}}/auth/login
Content-Type: application/json

{
  "login": "user_2",
  "password": "12345678"
}

### Login - login is required
POST {{host}}/auth/login
Content-Type: application/json

{
  "login": "",
  "password": "12345678"
}

### Login - password is required
POST {{host}}/auth/login
Content-Type: application/json

{
  "login": "admin",
  "password": ""
}

### Login - wrong password
POST {{host}}/auth/login
Content-Type: application/json

{
  "login": "admin",
  "password": "wrongpass123"
}

### Login - user not found
POST {{host}}/auth/login
Content-Type: application/json

{
  "login": "unknown_user",
  "password": "12345678"
}

### =====================================
### 6. ADMIN API - AUTHORIZATION CHECKS
### =====================================

### Get all non-admin users as admin
GET {{host}}/admin/users
Authorization: Bearer {{adminToken}}
Accept: application/json

### Get all non-admin users - no token
GET {{host}}/admin/users
Accept: application/json

### Get all non-admin users - invalid token format
GET {{host}}/admin/users
Authorization: Token abc123
Accept: application/json

### Get all non-admin users as normal user
GET {{host}}/admin/users
Authorization: Bearer {{userToken}}
Accept: application/json


### users delete test
### Delete user as admin
DELETE {{host}}/admin/users/{{userId}}
Authorization: Bearer {{adminToken}}
Accept: application/json

### Delete user as normal user
DELETE {{host}}/admin/users/{{userId}}
Authorization: Bearer {{userToken}}
Accept: application/json

### Delete user - no token
DELETE {{host}}/admin/users/{{userId}}
Accept: application/json

### Delete user - not found
DELETE {{host}}/admin/users/999999
Authorization: Bearer {{adminToken}}
Accept: application/json


### Logout (valid token)
POST {{host}}/auth/logout
Authorization: Bearer {{adminToken}}
Accept: application/json

### Logout - no token
POST {{host}}/auth/logout
Accept: application/json

### Logout - invalid token
POST {{host}}/auth/logout
Authorization: Bearer invalid_token
Accept: application/json
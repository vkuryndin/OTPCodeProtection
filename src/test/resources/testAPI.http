### =====================================
### 3. REGISTER - VALIDATION ERRORS
### =====================================

### Register - login is required
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "",
  "password": "12345678",
  "role": "USER"
}

### Register - login too short
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "ab",
  "password": "12345678",
  "role": "USER"
}

### Register - login invalid chars
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "user!*",
  "password": "12345678",
  "role": "USER"
}

### Register - password is required
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "user2",
  "password": "",
  "role": "USER"
}

### Register - password too short
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "user3",
  "password": "1234567",
  "role": "USER"
}

### Register - role is required
POST {{host}}/auth/register
Content-Type: application/json

{
  "login": "user4",
  "password": "12345678"
}


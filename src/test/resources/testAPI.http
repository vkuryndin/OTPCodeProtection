### =====================================
### 6. ADMIN API - AUTHORIZATION CHECKS
### =====================================

### Get all non-admin users as admin
GET {{host}}/admin/users
Authorization: Bearer {{adminToken}}
Accept: application/json

### Get all non-admin users - no token
GET {{host}}/admin/users
Accept: application/json

### Get all non-admin users - invalid token format
GET {{host}}/admin/users
Authorization: Token abc123
Accept: application/json

### Get all non-admin users as normal user
GET {{host}}/admin/users
Authorization: Bearer {{userToken}}
Accept: application/json

### =====================================
### 7. DELETE TESTS
### =====================================

### users delete test
### Delete user as admin
DELETE {{host}}/admin/users/{{userId}}
Authorization: Bearer {{adminToken}}
Accept: application/json

### Delete user as normal user
DELETE {{host}}/admin/users/{{userId}}
Authorization: Bearer {{userToken}}
Accept: application/json

### Delete user - no token
DELETE {{host}}/admin/users/{{userId}}
Accept: application/json

### Delete user - not found
DELETE {{host}}/admin/users/999999
Authorization: Bearer {{adminToken}}
Accept: application/json


### =====================================
### 8. LOGOUT
### =====================================

### Logout (valid token)
POST {{host}}/auth/logout
Authorization: Bearer {{adminToken}}
Accept: application/json

### Logout (valid token)
POST {{host}}/auth/logout
Authorization: Bearer {{userToken}}
Accept: application/json

### Logout - no token
POST {{host}}/auth/logout
Accept: application/json

### Logout - invalid token
POST {{host}}/auth/logout
Authorization: Bearer invalid_token
Accept: application/json

### =====================================
### 9. OTP - GET
### =====================================

### Get OTP config as admin
GET {{host}}/admin/otp-config
Authorization: Bearer {{adminToken}}
Accept: application/json

### Get OTP config as user
GET {{host}}/admin/otp-config
Authorization: Bearer {{userToken}}
Accept: application/json

### Get OTP config - no token
GET {{host}}/admin/otp-config
Accept: application/json

### Get OTP config - bad auth format
GET {{host}}/admin/otp-config
Authorization: Token abc123
Accept: application/json



### =====================================
### 10. OTP - UPDATE
### =====================================

### Update OTP config as admin
PUT {{host}}/admin/otp-config
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "codeLength": 6,
  "ttlSeconds": 300
}

### Update OTP config as user
PUT {{host}}/admin/otp-config
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "codeLength": 6,
  "ttlSeconds": 300
}

### Update OTP config - invalid codeLength
PUT {{host}}/admin/otp-config
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "codeLength": 3,
  "ttlSeconds": 300
}

### Update OTP config - invalid ttl
PUT {{host}}/admin/otp-config
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "codeLength": 6,
  "ttlSeconds": 0
}

### Update OTP config - missing codeLength
PUT {{host}}/admin/otp-config
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "ttlSeconds": 300
}

### Update OTP config - missing ttlSeconds
PUT {{host}}/admin/otp-config
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "codeLength": 6
}


### =====================================
### 11. OTP - GENERATE
### =====================================

### Generate OTP as user
POST {{host}}/otp/generate
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "operationId": "payment-001",
  "deliveryChannel": "FILE",
  "deliveryTarget": "otp-codes.txt"
}

### Generate OTP as admin
POST {{host}}/otp/generate
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "operationId": "admin-op-001",
  "deliveryChannel": "FILE",
  "deliveryTarget": "otp-codes.txt"
}

### Generate OTP - no token
POST {{host}}/otp/generate
Content-Type: application/json

{
  "operationId": "payment-002",
  "deliveryChannel": "FILE",
  "deliveryTarget": "otp-codes.txt"
}

### Generate OTP - missing operationId
POST {{host}}/otp/generate
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "deliveryChannel": "FILE",
  "deliveryTarget": "otp-codes.txt"
}

### Generate OTP - missing deliveryChannel
POST {{host}}/otp/generate
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "operationId": "payment-003",
  "deliveryTarget": "otp-codes.txt"
}

### Generate OTP - missing deliveryTarget
POST {{host}}/otp/generate
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "operationId": "payment-004",
  "deliveryChannel": "FILE"
}

### VALIDATE

### Validate OTP as user
POST {{host}}/otp/validate
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "operationId": "payment-001",
  "code": "PASTE_CODE_HERE"
}

### Validate OTP - wrong code
POST {{host}}/otp/validate
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "operationId": "payment-001",
  "code": "000000"
}

### Validate OTP - missing operationId
POST {{host}}/otp/validate
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "code": "123456"
}

### Validate OTP - missing code
POST {{host}}/otp/validate
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "operationId": "payment-001"
}

### Validate OTP - no token
POST {{host}}/otp/validate
Content-Type: application/json

{
  "operationId": "payment-001",
  "code": "123456"
}
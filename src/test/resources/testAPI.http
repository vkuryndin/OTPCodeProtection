### =====================================
### 0. FAST LOGIN
### =====================================

### Login as admin - valid
POST {{host}}/auth/login
Content-Type: application/json

{
  "login": "admin",
  "password": "12345678"
}
> {%
    client.global.set("adminToken", response.body.token);
    client.log("adminToken = " + client.global.get("adminToken"));
%}


### Login as user - valid
POST {{host}}/auth/login
Content-Type: application/json

{
  "login": "user_4",
  "password": "12345678"
}
> {%
    client.global.set("userToken", response.body.token);
    client.log("userToken = " + client.global.get("userToken"));
%}


